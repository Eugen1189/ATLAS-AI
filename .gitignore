# ==========================================
# AXIS Project .gitignore
# ==========================================

# --- SECRETS (CRITICAL — NEVER COMMIT) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
config.py

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
ENV/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.gemini/

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Testing & Coverage ---
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.ruff_cache/

# --- Project Specific ---
vision_buffer.png
response_audio.mp3
*.log
/logs/

# --- Model files (large binaries) ---
/model/

# --- Local data & memories (runtime state) ---
/memories/
/audio_output/
last_action.json
vision_*.png
*.db
/database/
/tmp/
/READY.txt
/error.log
