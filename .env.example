# ==========================================
# AXIS v2.5 — Environment Configuration
# ==========================================
# Copy this file to `.env` and fill in your real values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the `.env` file to git!
# ==========================================

# --- AI Brain Selection ---
# Options: gemini | ollama
AI_BRAIN=ollama
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Personality ---
# Blueprint name (filename without .yaml from core/blueprints/)
AXIS_BLUEPRINT=default

# --- Localization ---
# Options: en | uk | es
LANGUAGE=en

# --- API Keys (Required for cloud features) ---
# Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# OpenAI (for TTS voice output): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Telegram Bridge ---
# Create bot via @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Your chat ID (get via @userinfobot): https://t.me/userinfobot
TELEGRAM_CHAT_ID=
# Comma-separated user IDs allowed to send commands (whitelist)
TELEGRAM_ALLOWED_IDS=

# --- Optional: Web Research ---
# Perplexity AI: https://docs.perplexity.ai/
PERPLEXITY_API_KEY=

# --- Optional: GitHub MCP ---
# GitHub PAT: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Logging ---
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
